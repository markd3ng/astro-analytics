---
export interface Props {
  id?: string;
  src?: string;
  dataId?: string;
  site?: string;
  host?: string;
  dataHostUrl?: string;
  domains?: string | string[];
}

const {
  id,
  src,
  dataId,
  site,
  host = '/umami.js',
  dataHostUrl,
  domains,
} = Astro.props;

const websiteId = id ?? dataId;
const scriptSrc = src ?? (site ? new URL(host, site).href : undefined);
const normalizedDomains = Array.isArray(domains) ? domains.join(',') : domains;
---
<script
  async
  defer
  src={scriptSrc}
  data-website-id={websiteId}
  data-host-url={dataHostUrl}
  data-domains={normalizedDomains}
></script>
