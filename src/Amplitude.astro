---
export interface Props {
  apiKey: string;
  src?: string;
  serverZone?: 'US' | 'EU';
  autocapture?: boolean;
  fetchRemoteConfig?: boolean;
}

const {
  apiKey,
  src,
  serverZone = 'US',
  autocapture = true,
  fetchRemoteConfig = true,
} = Astro.props;

const scriptSrc = src ?? (serverZone === 'EU'
  ? `https://cdn.eu.amplitude.com/script/${apiKey}.js`
  : `https://cdn.amplitude.com/script/${apiKey}.js`);

const options = {
  autocapture,
  fetchRemoteConfig,
  ...(serverZone === 'EU' ? { serverZone: 'EU' as const } : {}),
};
---
<script define:vars={{ apiKey, scriptSrc, options }}>
  (function (w, d, src, key, config) {
    var script = d.createElement('script');
    script.async = true;
    script.src = src;
    script.onload = function () {
      if (w.amplitude?.init) {
        w.amplitude.init(key, config);
      }
    };

    var firstScript = d.getElementsByTagName('script')[0];

    if (firstScript?.parentNode) {
      firstScript.parentNode.insertBefore(script, firstScript);
      return;
    }

    d.head.appendChild(script);
  })(window, document, scriptSrc, apiKey, options);
</script>
